HUGGINGFACE_TOKEN=
INPUT_DIR=./input
OUTPUT_DIR=./output

# Web UI (http://localhost:8080, из LAN: http://<IP-сервера>:8080)
WEB_PORT=8080
ADMINER_PORT=8081
# make admin → sqlite-web (http://localhost:8081), без логина
APP_PASSWORD=
# если APP_PASSWORD задан — логин admin, пароль из переменной

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
QUEUE_NAME=sr_jobs

# Worker
LOWPASS=

# Локальный тест UI без GPU (worker-mock вместо flashsr)
# MOCK_MODE=0 → GPU-worker + AI в UI; MOCK_MODE=1 → только ffmpeg
MOCK_MODE=0
MOCK_DELAY_SEC=3

# Опционально переопределить UI (обычно не нужно — следует MOCK_MODE)
# ENHANCE_AVAILABLE=1

# Секреты в git: make encode → .env.vault (на сервере: make decode)
# Неинтерактивно: echo "пароль-vault" > .vault_pass && chmod 600 .vault_pass
